generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String     @id @default(cuid())
  clerkId   String     @unique
  email     String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  workspace Workspace?

  @@index([clerkId])
}

model Workspace {
  id                     String                  @id @default(cuid())
  name                   String
  slug                   String                  @unique
  logoUrl                String?
  isWhiteLabelEnabled    Boolean                 @default(false)
  stripeCustomerId       String?                 @unique
  googleRefreshToken     String?
  googleCalendarEnabled  Boolean                 @default(false)
  hubspotRefreshToken    String?
  hubspotEnabled         Boolean                 @default(false)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  userId                 String                  @unique
  appointmentSchedule    AppointmentSchedule?
  bookings               Booking[]
  domains                Domain[]
  leads                  Lead[]
  payments               Payment[]
  user                   User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  featureOverrides       WorkspaceFeature[]
  subscriptions          WorkspaceSubscription[]
}

model Domain {
  id                String    @id @default(cuid())
  workspaceId       String
  hostname          String    @unique
  iconUrl           String?
  isVerified        Boolean   @default(false)
  isPrimary         Boolean   @default(false)
  verificationToken String?   @unique
  verifiedAt            DateTime?
  lastVerifiedCheckAt   DateTime?
  createdAt             DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  chatbot           Chatbot?
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model Chatbot {
  id             String             @id @default(cuid())
  domainId       String             @unique
  welcomeMessage String             @default("Hi! How can I help you today?")
  primaryColor   String             @default("#6366f1")
  buttonStyle    ChatbotButtonStyle @default(BUBBLE)
  systemPrompt   String             @default("")
  isActive       Boolean             @default(true)
  borderRadius   ChatbotBorderRadius @default(MEDIUM)
  theme          ChatbotTheme        @default(LIGHT)
  chatTitle      String              @default("Support Chat")
  chatSubtitle   String              @default("AI Assistant • Online")
  createdAt      DateTime            @default(now())
  updatedAt      DateTime           @updatedAt
  domain         Domain             @relation(fields: [domainId], references: [id], onDelete: Cascade)
  questions      ChatbotQuestion[]
  sessions       ChatSession[]

  @@index([domainId])
}

model ChatbotQuestion {
  id        String   @id @default(cuid())
  chatbotId String
  text      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chatbot   Chatbot  @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  @@index([chatbotId, sortOrder])
}

model ChatSession {
  id          String            @id @default(cuid())
  chatbotId   String
  sessionUuid String            @unique @default(uuid())
  status      ChatSessionStatus @default(AI)
  portalToken String?           @unique
  metadata    Json?
  leadId      String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  chatbot     Chatbot           @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  lead        Lead?             @relation(fields: [leadId], references: [id], onDelete: SetNull)
  messages    ChatMessage[]

  @@index([chatbotId])
  @@index([sessionUuid])
  @@index([portalToken])
  @@index([leadId])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  role      MessageRole
  content   String
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model Plan {
  id                   String                  @id @default(cuid())
  code                 String                  @unique
  name                 String
  description          String?
  monthlyPriceCents    Int
  yearlyPriceCents     Int?
  stripePriceIdMonthly String?
  stripePriceIdYearly  String?
  isActive             Boolean                 @default(true)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  features             PlanFeature[]
  subscriptions        WorkspaceSubscription[]
  pendingSubscriptions WorkspaceSubscription[] @relation("PendingPlan")
}

model Feature {
  id                String             @id @default(cuid())
  code              String             @unique
  name              String
  description       String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  plans             PlanFeature[]
  workspaceSettings WorkspaceFeature[]
}

model PlanFeature {
  id         String   @id @default(cuid())
  planId     String
  featureId  String
  isEnabled  Boolean  @default(true)
  limitValue Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  feature    Feature  @relation(fields: [featureId], references: [id], onDelete: Cascade)
  plan       Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, featureId])
  @@index([featureId])
}

model WorkspaceFeature {
  id            String    @id @default(cuid())
  workspaceId   String
  featureId     String
  isEnabled     Boolean   @default(true)
  limitOverride Int?
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  feature       Feature   @relation(fields: [featureId], references: [id], onDelete: Cascade)
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, featureId])
  @@index([featureId])
}

model WorkspaceSubscription {
  id                     String                      @id @default(cuid())
  workspaceId            String
  planId                 String
  billingInterval        BillingInterval
  status                 WorkspaceSubscriptionStatus @default(TRIALING)
  stripeSubscriptionId   String?                     @unique
  stripePriceId          String?
  currentPeriodStartAt   DateTime?
  currentPeriodEndAt     DateTime?
  cancelAtPeriodEnd      Boolean                     @default(false)
  pendingPlanId          String?
  pendingBillingInterval BillingInterval?
  pendingStripePriceId   String?
  stripeScheduleId       String?                     @unique
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  plan                   Plan                        @relation(fields: [planId], references: [id])
  pendingPlan            Plan?                       @relation("PendingPlan", fields: [pendingPlanId], references: [id])
  workspace              Workspace                   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@index([planId])
}

model Lead {
  id          String     @id @default(cuid())
  workspaceId String
  email       String
  firstName   String?
  lastName    String?
  phone       String?
  source      String?
  status      LeadStatus @default(NEW)
  score       Int?
  notes       String?
  metadata          Json?
  hubspotContactId  String?
  hubspotSyncedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  bookings    Booking[]
  sessions    ChatSession[]
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  payments    Payment[]

  @@unique([workspaceId, email])
  @@unique([id, workspaceId])
  @@index([workspaceId, status, createdAt])
  @@index([hubspotContactId])
}

model Booking {
  id                  String        @id @default(cuid())
  workspaceId         String
  leadId              String?
  title               String
  startsAt            DateTime
  endsAt              DateTime
  timezone            String
  status              BookingStatus @default(PENDING)
  meetingLink         String?
  externalCalendarRef String?
  expectedValueCents  Int?
  note                String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  lead                Lead?         @relation(fields: [leadId], references: [id])
  workspace           Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  payments            Payment[]

  @@unique([id, workspaceId])
  @@index([workspaceId, startsAt])
  @@index([leadId])
}

model Payment {
  id                    String        @id @default(cuid())
  workspaceId           String
  leadId                String?
  bookingId             String?
  amountCents           Int
  currency              String        @default("USD")
  status                PaymentStatus @default(PENDING)
  stripePaymentIntentId String?       @unique
  stripeChargeId        String?       @unique
  stripeCustomerId      String?
  paidAt                DateTime?
  refundedAt            DateTime?
  metadata              Json?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  booking               Booking?      @relation(fields: [bookingId], references: [id])
  lead                  Lead?         @relation(fields: [leadId], references: [id])
  workspace             Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([id, workspaceId])
  @@index([workspaceId, status, createdAt])
  @@index([leadId])
  @@index([bookingId])
}

model AppointmentSchedule {
  id            String    @id @default(cuid())
  workspaceId   String    @unique
  isEnabled     Boolean   @default(true)
  slotDuration  Int       @default(60)
  bufferMinutes Int       @default(0)
  timezone      String    @default("UTC")
  schedule      Json      @default("{}")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

enum ChatbotButtonStyle {
  BUBBLE
  BAR
}

enum ChatbotBorderRadius {
  NONE
  SMALL
  MEDIUM
  LARGE
  FULL
}

enum ChatbotTheme {
  LIGHT
  DARK
}

enum ChatSessionStatus {
  AI
  HUMAN
  CLOSED
}

enum MessageRole {
  user
  assistant
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  WON
  LOST
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  CANCELLED
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum WorkspaceSubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}
